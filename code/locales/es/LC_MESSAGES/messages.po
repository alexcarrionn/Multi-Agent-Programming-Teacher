msgid "ERROR EMAIL NOT FROM UM"
msgstr "Error: el correo introducido no es válido. Por favor, introduce un correo de la Universidad de Murcia (terminado en @um.es).\n"

msgid "ERROR EMAIL NOT AUTHORIZED"
msgstr "Error: el correo introducido no está autorizado para registrarse. Por favor, contacta con tu docente para obtener acceso.\n"

msgid "INPUT EMAIL"
msgstr "Introduce tu correo: "

